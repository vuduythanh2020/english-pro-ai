# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# OpenAI Base URL (optional, set this if using 3rd party provider or proxy)
OPENAI_BASE_URL=

# Anthropic API Key (required for Claude) - Can be 3rd party key
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
# Anthropic Base URL (optional, set this if using 3rd party provider or proxy)
ANTHROPIC_BASE_URL=

# Server
PORT=3000
NODE_ENV=development

# Workflow Configuration
# Set to 'true' to auto-approve all workflow steps without waiting for PM
AUTO_APPROVE_ENABLED=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password123@localhost:5432/celestial_flare

# Or you can use individual variables (if DATABASE_URL is not provided)
# DB_USER=postgres
# DB_PASSWORD=password123
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=celestial_flare

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET=dev-jwt-secret-change-in-production
# Token expiration time in seconds (86400 = 24 hours)
JWT_EXPIRES_IN=86400

# ============================================================================
# GOOGLE OAUTH
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback